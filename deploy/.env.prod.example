# DEMS production env — copy to deploy/.env on the VPS and fill with real values.
# deploy/.env is git-ignored; NEVER commit real secrets.

# Postgres password for the dems DB (compose interpolates it into DATABASE_URL).
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# JWT signing secret. Generate: openssl rand -hex 32
JWT_SECRET=

# Optional overrides (defaults shown).
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=2592000
RUST_LOG=dems_api=info,tower_http=info,sqlx=warn
