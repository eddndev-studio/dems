# === DEMS API — configuración (servidor Windows offline) ===
# El ejecutable lee este archivo (.env) desde su misma carpeta.
# El pipeline de CI genera un .env con un JWT_SECRET aleatorio en el bundle;
# este .example es la plantilla de referencia.

DATABASE_URL=postgres://dems:dems@localhost:5432/dems

# 0.0.0.0 = escuchar en TODAS las interfaces (para que los dispositivos
# de la LAN alcancen la IP de esta máquina).
API_HOST=0.0.0.0
API_PORT=8080

# Secreto para firmar tokens. Genera uno estable, p.ej. en PowerShell:
#   -join ((48..57)+(97..102) | Get-Random -Count 64 | % {[char]$_})
JWT_SECRET=__GENERA_UN_VALOR_ALEATORIO__
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=2592000

RUST_LOG=dems_api=info,tower_http=warn,sqlx=warn
