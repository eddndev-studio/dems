DATABASE_URL=postgres://dems:dems@localhost:5433/dems
API_HOST=0.0.0.0
API_PORT=8080
JWT_SECRET=change-me-in-production
# Access token: 1h. El cliente refresca automáticamente con el refresh token (30d).
JWT_ACCESS_TTL_SECS=3600
JWT_REFRESH_TTL_SECS=2592000
# Swagger UI (/docs) + /openapi.json en runtime. Ponlo en false en PRODUCCIÓN
# para no exponer el esquema completo del API a cualquiera.
ENABLE_DOCS=true
RUST_LOG=dems_api=debug,tower_http=debug,sqlx=warn
